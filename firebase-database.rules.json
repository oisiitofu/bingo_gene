{
  "rules": {
    ".read": false,
    ".write": false,
    "teamBingoV1": {
      ".read": "auth != null",
      "rooms": {
        "$roomId": {
          ".write": "auth != null && (!data.exists() || data.child('meta').child('masterUid').val() === auth.uid || data.child('participants').child(auth.uid).exists() || newData.child('participants').child(auth.uid).exists() || root.child('teamBingoV1').child('adminSessions').child(auth.uid).child('expiresAt').val() > now || (!newData.exists() && data.child('meta').child('updatedAt').val() < now - 86400000))",
          ".validate": "!newData.exists() || (newData.hasChildren(['meta', 'setup', 'participants']) && newData.child('meta').hasChildren(['id', 'masterUid', 'revision', 'eventSeq', 'active']))"
        }
      },
      "lobby": {
        "$roomId": {
          ".write": "auth != null",
          ".validate": "!newData.exists() || newData.hasChildren(['active', 'phase', 'updatedAt'])"
        }
      },
      "globalStats": {
        ".write": "auth != null"
      },
      "legacyImports": {
        "$deviceId": {
          ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid)",
          ".validate": "newData.hasChildren(['importedAt', 'uid']) && newData.child('uid').val() === auth.uid"
        }
      },
      "adminSessions": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.hasChildren(['pinHash', 'expiresAt']) && newData.child('pinHash').val() === '6440e6a91202aeddb45b070a80533f65a689c37d0cf1842ab2bd962e33377880' && newData.child('expiresAt').isNumber() && newData.child('expiresAt').val() > now && newData.child('expiresAt').val() <= now + 1800000"
        }
      },
      "adminUid": {
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || data.val() === auth.uid)"
      }
    }
  }
}
